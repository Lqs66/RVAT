+
+int main() {
+  double x = 0.0f;
+  klee_make_symbolic(&x, sizeof(double), "x");
+
+  double result = fabs(x);
+
+  if (isnan(x)) {
+    if (signbit(x)) {
+      // CHECK-DAG: -ve nan
+      printf("-ve nan\n");
+    } else {
+      // CHECK-DAG: +ve nan
+      printf("+ve nan\n");
+    }
+    assert(isnan(result));
+    return 0;
+  }
+
+  if (isinf(x)) {
+    if (signbit(x)) {
+      // CHECK-DAG: -ve inf
+      printf("-ve inf\n");
+    } else {
+      // CHECK-DAG: +ve inf
+      printf("+ve inf\n");
+    }
+    assert(!signbit(result));
+    assert(isinf(result) == 1);
+    return 0;
+  }
+
+  if (x == 0.0) {
+    if (signbit(x)) {
+      // CHECK-DAG: -ve 0.0
+      printf("-ve 0.0\n");
+    } else {
+      // CHECK-DAG: +ve 0.0
+      printf("+ve 0.0\n");
+    }
+    assert(!signbit(result));
+    assert(result == 0.0);
+    return 0;
+  }
+
+  // CHECK-DAG: result > 0.0
+  printf("result > 0.0\n");
+  assert(result > 0.0);
+
+  return 0;
+}
