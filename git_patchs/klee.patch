+  // [0] [000000000000001] [0]     [0000...1]
+  const uint64_t lowBits = 0x0000000000000001;
+  const uint16_t highBits = 0x0001;
+  long double v = 0.0l;
+  memcpy(&v, &lowBits, sizeof(lowBits));       // 64 bits
+  memcpy(((uint8_t *)(&v)) + 8, &highBits, 2); // 16 bits
