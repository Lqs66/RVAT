+void Executor::concreteCall(ExecutionState &state, KInstruction *ki, Function *f,
+                            std::vector<ref<Expr>> &arguments) {
+ 
+  KFunction* kf = kmodule->functionMap[f];
+  klee_warning("Executing call concretely: %s", f->getName().str().c_str());
+
+  // First, calculate all argument values in the caller's stack frame (from the original state)
+  std::vector<ref<Expr>> argValues;
+  for (unsigned i = 0; i < arguments.size(); ++i) {
+    ref<ConstantExpr> concreteValue = toConstant(state, arguments[i],
+                                                 "concretizing argument for concrete execution", false);
+    argValues.push_back(concreteValue);
+  }
+
+  // Create shadowState
+  ExecutionState *shadowState = state.branch();
+  shadowState->isConcrete = true;
+  klee_warning("Created shadow state (ID: %u) for concrete execution", shadowState->getID());
+
+  struct ByteBackup {
+    const MemoryObject *mo;
+    unsigned offset;
+    ref<Expr> originalValue;
+  };
+  std::vector<ByteBackup> modifiedBytes;
+ 
+  // Concretize all symbolic memory objects in shadowState
+  for (auto obj_it = shadowState->addressSpace.objects.begin();
+       obj_it != shadowState->addressSpace.objects.end(); ++obj_it) {
+    const MemoryObject *mo = obj_it->first;
+    ObjectState *os = obj_it->second.get();
+
+    for (unsigned i = 0; i < mo->size; i++) {
+      if (!os->isByteConcrete(i)) {
+
+        modifiedBytes.push_back({mo, i, os->read8(i)});
+
+        ref<Expr> val = os->read8(i);
+        ref<ConstantExpr> concrete = toConstant(*shadowState, val, "concretizing memory", false);
+        os->write(i, concrete);
+      }
+    }
+  }
+
+  // Push the called function onto shadowState's stack
+  shadowState->pushFrame(shadowState->prevPC, kf);
+
+  // Bind arguments to the new stack frame (using concrete values)
+  for (unsigned i = 0; i < arguments.size(); ++i) {
+    bindArgument(kf, i, *shadowState, argValues[i]);
+  }
+
+  shadowState->pc = kf->instructions;
+
+  // Run the interpreter loop on the shadow state until it returns.
+  const unsigned initialStackSize = shadowState->stack.size();
+
+  // Temporarily disable stats tracking
+  StatsTracker *originalStatsTracker = statsTracker;
+  statsTracker = nullptr;
+
+  while (!shadowState->concreteHalt && shadowState->stack.size() >= initialStackSize) {
+    KInstruction *current_ki = shadowState->pc;
+    // for debug
+    // llvm::outs() << "Executing instruction: " << *current_ki->inst << "\n";
+    stepInstruction(*shadowState);
+    executeInstruction(*shadowState, current_ki);
+    timers.invoke();
+  }
+
+  // Restore stats tracking
+  statsTracker = originalStatsTracker;
+
+  if (shadowState->concreteHalt) {
+    klee_warning("Shadow state halted during concrete execution. Terminating original state.");
+    delete shadowState;
+    terminateState(state, StateTerminationType::Execution);
+    return;
+  }
+
+  // Merge return value back into the original state.
+  if (f->getReturnType()->isVoidTy() == false) {
+    ref<Expr> returnValue = shadowState->stack.back().locals[ki->dest].value;
+    assert(isa<ConstantExpr>(returnValue) &&
+           "Return value should be a constant after concrete execution");
+    bindLocal(ki, state, returnValue);
+  }
+
+  for (const auto& backup : modifiedBytes) {
+    auto orig_obj_it = state.addressSpace.objects.find(backup.mo);
+    if (orig_obj_it != state.addressSpace.objects.end()) {
+      ObjectState *origOS = orig_obj_it->second.get();
+      ObjectState *writableOS = state.addressSpace.getWriteable(backup.mo, origOS);
+      writableOS->write(backup.offset, backup.originalValue);
+    }
+  }
+
+  // Clean up shadowState
+  delete shadowState;
+}
