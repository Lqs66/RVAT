+bool Executor::handleCallDepthLimit(ExecutionState &state, KInstruction *ki, Function *f,
+                                    std::vector<ref<Expr>> &arguments) {
+  // Check if split mode and max call depth are enabled
+  if (!EnableSplit || MaxCallDepth <= 0) {
+    return false;
+  }
+
+  long curr_call_depth = state.stack.back().depth;
+
+  if (state.isConcrete) {
+    return false; // No need to handle call depth for concrete states
+  }
+
+  // Check if max call depth is reached and state is not already concrete
+  if (curr_call_depth >= MaxCallDepth) {
+    klee_warning("max-call-depth reached. Current state id: %u, Current call depth: %lu, maximum allowed: %u",
+                 state.getID(), curr_call_depth, MaxCallDepth.getValue());
+ 
+    // Execute the call concretely
+    concreteCall(state, ki, f, arguments);
+  
+    return true; // Indicate that the call was handled
+  }
+  return false; // Indicate that the call was not handled
+}
