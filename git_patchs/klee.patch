diff -uNr -x .git klee/runtime/klee-fp/trigonometry.c klee-3.1/runtime/klee-fp/trigonometry.c
--- klee/runtime/klee-fp/trigonometry.c	1970-01-01 08:00:00.000000000 +0800
+++ klee-3.1/runtime/klee-fp/trigonometry.c	2026-01-14 16:37:23.044799245 +0800
@@ -0,0 +1,29 @@
+double const eps = 1e-8;
+
+double sin(double x) {
+    double result = 0.0;
+    double xpow = x;
+    int kfact = 1;
+    int k;
+    for (k = 0; k < 3; k++) {
+        int sign = (k % 2) ? -1 : 1;
+        result += sign * xpow / kfact;
+        xpow *= x * x;
+        kfact *= (2 * k + 2) * (2 * k + 3);
+    }
+    return result;
+}
+
+double cos(double x) {
+    double result = 0.0;
+    double xpow = 1;
+    int kfact = 1;
+    int k;
+    for (k = 0; k < 3; k++) {
+        int sign = (k % 2) ? -1 : 1;
+        result += sign * xpow / kfact;
+        xpow *= x * x;
+        kfact *= (2 * k + 1) * (2 * k + 2);
+    }
+    return result;
+}
