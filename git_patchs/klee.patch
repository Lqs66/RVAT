+  klee_make_symbolic(&x, sizeof(float), "x");
+  float result = sqrtf(x);
+
+  if (isnan(x)) {
+    assert(isnan(result));
+    return 0;
+  }
+
+  if (x < 0.0f) {
+    assert(isnan(result));
+    return 0;
+  }
+
+  if (isinf(x)) {
+    assert(isinf(result) == 1);
+    return 0;
+  }
+
+  if (x == 0.0f) {
+    assert(result == 0.0f);
+    // check sign bit sqrt(-0.0) == -0.0
+    if (signbit(x)) {
+      assert(signbit(result));
+    }
+    return 0;
+  }
+
+  assert(x > 0.0f);
