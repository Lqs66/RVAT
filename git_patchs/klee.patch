+// RUN: %clang %s -emit-llvm -O0 -g -c -o %t1.bc
+// RUN: rm -rf %t.klee-out
+// RUN: %klee --libc=klee --solver-backend=z3 --fp-runtime --output-dir=%t.klee-out  %t1.bc > %t-output.txt 2>&1
