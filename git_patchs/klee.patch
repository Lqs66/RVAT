+ref<ConstantExpr> ConstantExpr::FAdd(const ref<ConstantExpr> &RHS,
+                                     llvm::APFloat::roundingMode rm) const {
+  ref<ConstantExpr> nanEval = tryBinaryOpNaNArgs(this, RHS.get());
+  if (nanEval.get())
