+        for (auto it = allStates.begin(); it != allStates.end(); ++it) {
+            ExecutionState *s = *it;
+            size_t newCount = 0;
+            for (auto *bb : s->visitedBBs) {
+                if (covered.find(bb) == covered.end()) {
