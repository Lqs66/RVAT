--- klee/test/Floats/fegetround_fesetround.c	1970-01-01 08:00:00.000000000 +0800
+++ klee-3.1/test/Floats/fegetround_fesetround.c	2026-01-14 16:37:23.067798840 +0800
@@ -0,0 +1,38 @@
+// RUN: %clang %s -emit-llvm -O0 -g -c -o %t1.bc
+// RUN: rm -rf %t.klee-out
+// RUN: %klee --libc=klee --solver-backend=z3 --fp-runtime --output-dir=%t.klee-out --exit-on-error %t1.bc
+// REQUIRES: fp-runtime
+#include "klee/klee.h"
+#include <assert.h>
+#include <fenv.h>
+
+
+int main() {
+  int rm = fegetround();
+  int result = 0;
+  int newRm = 0;
+  assert(rm == FE_TONEAREST);
+
+  newRm = FE_UPWARD;
+  result = fesetround(newRm);
+  assert(result == 0 && "success");
+  assert(fegetround() == newRm);
+
+  newRm = FE_DOWNWARD;
+  result = fesetround(newRm);
+  assert(result == 0 && "success");
+  assert(fegetround() == newRm);
+
+  newRm = FE_TOWARDZERO;
+  result = fesetround(newRm);
+  assert(result == 0 && "success");
+  assert(fegetround() == newRm);
+
+  // Bad rounding mode
+  int tryRm = 0x7ff3;
+  result = fesetround(tryRm);
+  assert(result != 0 && "expected failure");
+  assert(fegetround() != tryRm);
+  assert(fegetround() == newRm);
+  return 0;
+}
